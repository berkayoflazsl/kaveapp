# API (ngrok "api" tüneli)
EXPO_PUBLIC_API_URL=https://YOUR-API-SUBDOMAIN.ngrok-free.app

# Supabase: Project Settings > API (anon = public, safe in Expo)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon

# Metro — ngrok "metro" tünelinin tam HTTPS adresi (npm run sync:ngrok yazar)
# Olmadan Expo manifest http://...:8081 üretir; dışarıdan ngrok :8081 dinlemez → Expo Go hata verir.
EXPO_PACKAGER_PROXY_URL=https://YOUR-METRO-SUBDOMAIN.ngrok-free.app
